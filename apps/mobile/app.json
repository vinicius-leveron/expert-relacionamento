{
  "expo": {
    "name": "Perpétuo",
    "slug": "kosmos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "perpetuo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.perpetuo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "package": "com.perpetuo.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite que você escolha imagens para enviar no chat.",
          "cameraPermission": "Permite que você tire fotos para enviar no chat."
        }
      ],
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://perpetuo-api-fdrf.onrender.com/api/v1",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a7e13cfb-cc06-4cdf-b407-3ad100fd92a5"
      }
    }
  }
}
