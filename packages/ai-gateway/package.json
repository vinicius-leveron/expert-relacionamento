{
  "name": "@perpetuo/ai-gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "default": "./dist/providers/index.js"
    },
    "./embeddings": {
      "types": "./dist/embeddings/index.d.ts",
      "default": "./dist/embeddings/index.js"
    },
    "./rag": {
      "types": "./dist/rag/index.d.ts",
      "default": "./dist/rag/index.js"
    },
    "./transcription": {
      "types": "./dist/transcription/index.d.ts",
      "default": "./dist/transcription/index.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "default": "./dist/context/index.js"
    },
    "./prompts": {
      "types": "./dist/prompts/index.d.ts",
      "default": "./dist/prompts/index.js"
    },
    "./diagnostic": {
      "types": "./dist/diagnostic/index.d.ts",
      "default": "./dist/diagnostic/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@perpetuo/core": "workspace:*",
    "@supabase/supabase-js": "^2.45.0"
